---
interface Props {
  href?: string
  variant?: 'primary' | 'secondary' | 'ghost'
  type?: 'button' | 'submit'
  class?: string
  ariaLabel?: string
}
const { href, variant = 'primary', type = 'button', class: extraClass = '', ariaLabel } = Astro.props
const cls = `btn btn-${variant} ${extraClass}`.trim()
const Tag = href ? 'a' : 'button'
---
<Tag class={cls} {...href ? { href } : { type }} aria-label={ariaLabel}>
  <slot />
</Tag>

<style is:global>
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 20px; border-radius: 0;
    font-size: 0.9375rem; font-weight: 500; text-decoration: none;
    border: 1px solid transparent; cursor: pointer;
    min-height: 44px; font-family: var(--font-display);
    transition: background .15s ease, border-color .15s ease, color .15s ease;
  }
  /* Solid ink fill themes correctly in both modes (paper text on ink). */
  .btn-primary { background: var(--ink); color: var(--paper); font-weight: 600; }
  .btn-primary:hover { background: var(--sheen); color: var(--paper); }
  .btn-secondary { background: transparent; color: var(--ink); border-color: var(--ink-12); }
  .btn-secondary:hover { border-color: var(--sheen); color: var(--sheen); background: var(--ink-06); }
  .btn-ghost { background: transparent; color: var(--ink-70); padding: 12px 14px; }
  .btn-ghost:hover { color: var(--sheen); }
</style>
