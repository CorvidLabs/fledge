---
interface Props { type?: 'note' | 'warn' | 'tip' }
const { type = 'note' } = Astro.props
---
<aside class={`callout callout-${type}`}>
  <slot />
</aside>

<style is:global>
  .callout { padding: 16px 18px; border-left: 3px solid var(--sheen);
    background: var(--ink-06); border-radius: 0; margin: 20px 0; }
  .callout p:last-child { margin-bottom: 0; }
  .callout strong { color: var(--sheen-strong); }
  .callout-warn { border-left-color: var(--warning); }
  .callout-warn strong { color: var(--warning); }
  .callout-tip { border-left-color: var(--success); }
  .callout-tip strong { color: var(--success); }
</style>
