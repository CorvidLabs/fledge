---
interface Props {
  title?: string
  ariaLabel?: string
}
const { title = 'terminal', ariaLabel = 'Terminal example' } = Astro.props
---
<figure class="terminal" aria-label={ariaLabel}>
  <div class="term-header">
    <div class="term-dots" aria-hidden="true">
      <span class="d1"></span><span class="d2"></span><span class="d3"></span>
    </div>
    <span class="term-title">{title}</span>
  </div>
  <div class="term-body">
    <slot />
  </div>
</figure>

<style is:global>
  .terminal {
    background: var(--surface); border: 1px solid var(--ink-12);
    border-radius: 0; overflow: hidden;
    font-family: var(--font-mono); font-size: 0.9375rem; line-height: 1.85;
  }
  .term-header { display: flex; align-items: center; gap: 12px; padding: 12px 16px;
    background: var(--ink-06); border-bottom: 1px solid var(--border); }
  .term-dots { display: flex; gap: 6px; }
  .term-dots span { width: 12px; height: 12px; border-radius: 50%; }
  .term-dots .d1 { background: var(--danger); }
  .term-dots .d2 { background: var(--warning); }
  .term-dots .d3 { background: var(--success); }
  .term-title { color: var(--ink-70); font-size: 0.8125rem; }
  .term-body { padding: 20px 22px; }
  .term-line { white-space: pre-wrap; word-break: break-word; }
  .term-prompt { color: var(--sheen-strong); }
  .term-out { color: var(--ink-70); }
  .term-good { color: var(--success); }
  .term-comment { color: var(--ink-45); font-style: italic; }
  .blink { display: inline-block; width: 8px; height: 16px;
    background: var(--sheen); vertical-align: middle; margin-left: 2px; }
  @media (prefers-reduced-motion: no-preference) {
    .blink { animation: blink 1.1s infinite; }
    @keyframes blink { 0%,49% { opacity: 1; } 50%,100% { opacity: 0; } }
  }
</style>
