---
type Category = 'announce' | 'plugin' | 'release' | 'workflow' | 'tutorial'
interface Props { category: Category }
const labels: Record<Category, string> = {
  announce: 'Announcement',
  plugin: 'Plugin',
  release: 'Release',
  workflow: 'Workflow',
  tutorial: 'Tutorial',
}
const { category } = Astro.props
---
<span class={`tag tag-${category}`}>{labels[category]}</span>

<style is:global>
  .tag {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 3px 10px; border-radius: 0; font-size: 0.75rem; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
    background: var(--ink-06); border: 1px solid currentColor;
    font-family: var(--font-mono);
  }
  /* Categorical — brand chart palette, distinguishable, never purple. */
  .tag-announce  { color: var(--chart-5); }
  .tag-plugin    { color: var(--chart-4); }
  .tag-release   { color: var(--chart-3); }
  .tag-workflow  { color: var(--chart-2); }
  .tag-tutorial  { color: var(--chart-1); }
</style>
